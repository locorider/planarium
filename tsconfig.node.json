{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": false,
    "outDir": "dist",
    "sourceMap": true,
    "types": ["node"]
  },
  "include": ["src/cli.ts", "src/server/**/*.ts"],
  "exclude": ["src/**/*.test.ts"]
}
