{
  "name": "planarium",
  "version": "0.1.0",
  "description": "A portable local viewer for .planning epic workspaces.",
  "type": "module",
  "bin": {
    "planarium": "./dist/cli.js"
  },
  "files": [
    "dist",
    "index.html",
    "public",
    "src",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.node.json && tsc --noEmit && vite build",
    "prepare": "npm run build",
    "preview": "vite preview --host 0.0.0.0 --port 9010",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "planning",
    "epics",
    "viewer",
    "vite"
  ],
  "license": "MIT",
  "dependencies": {
    "@ant-design/icons": "^6.2.5",
    "@vitejs/plugin-react": "^4.3.4",
    "antd": "^6.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.7"
  }
}
